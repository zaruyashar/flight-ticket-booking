<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Barlow+Condensed:wght@300;400;600;700&family=Barlow:wght@300;400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.3/font/bootstrap-icons.min.css">

<style>
    /* ── CSS Variables ── */
    :root {
      --burgundy-deep:  #1a0508;
      --burgundy-mid:   #3b0a12;
      --burgundy-light: #5c1624;
      --burgundy-glow:  #8b1a2a;
      --accent-amber:   #e8b94f;
      --accent-amber-dim: rgba(232,185,79,.15);
      --text-primary:   #f0e6d3;
      --text-dim:       rgba(240,230,211,.55);
      --text-muted:     rgba(240,230,211,.32);
      --border:         rgba(232,185,79,.18);
      --border-subtle:  rgba(240,230,211,.08);
      --glass:          rgba(255,255,255,.03);
      --glass-hover:    rgba(255,255,255,.065);

      /* Status colours */
      --s-green:  #22c55e;
      --s-blue:   #38bdf8;
      --s-orange: #f97316;
      --s-red:    #ef4444;
      --s-yellow: #eab308;
      --s-purple: #a78bfa;
      --s-gray:   #94a3b8;
    }

    /* ── Section shell ── */
    .brand-area.brand-bg {
      background: linear-gradient(160deg, #1a0508 0%, #2d0910 40%, #1f060d 100%);
      padding: 64px 0 72px;
      position: relative;
      overflow: hidden;
      font-family: 'Barlow', sans-serif;
    }

    /* Decorative scanline overlay */
    .brand-area.brand-bg::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image: repeating-linear-gradient(
        0deg,
        transparent,
        transparent 3px,
        rgba(0,0,0,.12) 3px,
        rgba(0,0,0,.12) 4px
      );
      pointer-events: none;
      z-index: 0;
    }

    /* Ambient glow orbs */
    .brand-area.brand-bg::after {
      content: '';
      position: absolute;
      width: 600px; height: 600px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(139,26,42,.35) 0%, transparent 70%);
      top: -200px; right: -150px;
      pointer-events: none;
      z-index: 0;
    }

    .fsd-glow-left {
      position: absolute;
      width: 400px; height: 400px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(232,185,79,.07) 0%, transparent 70%);
      bottom: -150px; left: -100px;
      pointer-events: none;
      z-index: 0;
    }

    .fsd-container { position: relative; z-index: 1; }

    /* ── Header area ── */
    .fsd-header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-bottom: 36px;
      flex-wrap: wrap;
      gap: 16px;
    }

    .fsd-title-block {}

    .fsd-eyebrow {
      font-family: 'Share Tech Mono', monospace;
      font-size: 11px;
      letter-spacing: .25em;
      color: var(--accent-amber);
      text-transform: uppercase;
      margin-bottom: 6px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .fsd-eyebrow::before {
      content: '';
      display: inline-block;
      width: 20px; height: 1px;
      background: var(--accent-amber);
    }

    .fsd-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: clamp(28px, 4vw, 42px);
      font-weight: 700;
      color: var(--text-primary);
      letter-spacing: .02em;
      line-height: 1;
      margin: 0;
      text-transform: uppercase;
    }

    .fsd-live-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 5px 12px;
      background: rgba(34,197,94,.12);
      border: 1px solid rgba(34,197,94,.3);
      border-radius: 20px;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: .1em;
      color: var(--s-green);
      text-transform: uppercase;
      font-family: 'Share Tech Mono', monospace;
    }

    .fsd-live-dot {
      width: 7px; height: 7px;
      border-radius: 50%;
      background: var(--s-green);
      animation: pulse-dot 2s infinite;
    }

    @@keyframes pulse-dot {
      0%, 100% { opacity: 1; transform: scale(1); }
      50%       { opacity: .5; transform: scale(.7); }
    }

    /* ── Tabs ── */
    .fsd-tabs {
      display: flex;
      gap: 4px;
      background: rgba(0,0,0,.3);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 4px;
      margin-bottom: 24px;
      width: fit-content;
    }

    .fsd-tab-btn {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 14px;
      font-weight: 600;
      letter-spacing: .08em;
      text-transform: uppercase;
      color: var(--text-dim);
      background: transparent;
      border: none;
      border-radius: 7px;
      padding: 9px 28px;
      cursor: pointer;
      transition: all .25s ease;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .fsd-tab-btn i { font-size: 15px; }

    .fsd-tab-btn:hover {
      color: var(--text-primary);
      background: var(--glass-hover);
    }

    .fsd-tab-btn.active {
      background: linear-gradient(135deg, var(--burgundy-glow), var(--burgundy-light));
      color: var(--accent-amber);
      box-shadow: 0 2px 16px rgba(139,26,42,.5);
    }

    /* ── Stats bar ── */
    .fsd-stats {
      display: flex;
      gap: 24px;
      margin-bottom: 20px;
      flex-wrap: wrap;
    }

    .fsd-stat {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 12px;
      color: var(--text-dim);
      font-family: 'Share Tech Mono', monospace;
    }

    .fsd-stat-dot {
      width: 8px; height: 8px;
      border-radius: 50%;
      flex-shrink: 0;
    }

    /* ── Table wrapper ── */
    .fsd-table-wrap {
      overflow-x: auto;
      border-radius: 12px;
      border: 1px solid var(--border);
      background: rgba(0,0,0,.25);
    }

    /* ── Column header row ── */
    .fsd-col-headers {
      display: grid;
      grid-template-columns: 180px 110px 1fr 1fr 100px 90px 80px 160px;
      gap: 0;
      padding: 11px 20px;
      border-bottom: 1px solid var(--border);
      background: rgba(0,0,0,.35);
    }

    .fsd-col-label {
      font-family: 'Share Tech Mono', monospace;
      font-size: 10px;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: var(--text-muted);
      white-space: nowrap;
    }

    /* ── Flight row ── */
    .fsd-flight-row {
      display: grid;
      grid-template-columns: 180px 110px 1fr 1fr 100px 90px 80px 160px;
      gap: 0;
      padding: 14px 20px;
      border-bottom: 1px solid var(--border-subtle);
      align-items: center;
      transition: background .2s ease;
      cursor: default;
      position: relative;
    }

    .fsd-flight-row:last-child { border-bottom: none; }

    .fsd-flight-row::before {
      content: '';
      position: absolute;
      left: 0; top: 0; bottom: 0;
      width: 3px;
      border-radius: 0 2px 2px 0;
      background: transparent;
      transition: background .2s ease;
    }

    .fsd-flight-row:hover {
      background: var(--glass-hover);
    }

    .fsd-flight-row:hover::before {
      background: var(--accent-amber);
    }

    /* Cells */
    .fsd-cell {
      padding-right: 12px;
      display: flex;
      align-items: center;
      min-width: 0;
    }

    /* Airline cell */
    .fsd-airline {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .fsd-airline-icon {
      width: 34px; height: 34px;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 16px;
      flex-shrink: 0;
      font-weight: 700;
      font-family: 'Barlow Condensed', sans-serif;
      letter-spacing: 0;
    }

    .fsd-airline-name {
      font-size: 13px;
      font-weight: 600;
      color: var(--text-primary);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    /* Flight number */
    .fsd-fnum {
      font-family: 'Share Tech Mono', monospace;
      font-size: 13px;
      color: var(--accent-amber);
      letter-spacing: .05em;
    }

    /* Route */
    .fsd-route {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 13px;
      color: var(--text-primary);
      white-space: nowrap;
    }

    .fsd-route-arrow {
      color: var(--text-muted);
      font-size: 10px;
    }

    .fsd-iata {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 600;
      font-size: 15px;
      letter-spacing: .05em;
    }

    .fsd-city {
      font-size: 11px;
      color: var(--text-dim);
    }

    /* Time */
    .fsd-time {
      font-family: 'Share Tech Mono', monospace;
      font-size: 15px;
      color: var(--text-primary);
      letter-spacing: .05em;
    }

    /* Gate / Terminal */
    .fsd-gate, .fsd-terminal {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 15px;
      font-weight: 600;
      color: var(--text-primary);
      letter-spacing: .05em;
    }

    .fsd-gate-num {
      display: inline-block;
      padding: 2px 8px;
      background: var(--accent-amber-dim);
      border: 1px solid rgba(232,185,79,.25);
      border-radius: 5px;
      font-size: 13px;
      color: var(--accent-amber);
    }

    /* Status badge */
    .fsd-status {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 4px 11px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: .06em;
      text-transform: uppercase;
      font-family: 'Barlow Condensed', sans-serif;
      white-space: nowrap;
    }

    .fsd-status i { font-size: 11px; }

    .s-green  { background: rgba(34,197,94,.12);  border: 1px solid rgba(34,197,94,.3);  color: var(--s-green); }
    .s-blue   { background: rgba(56,189,248,.12); border: 1px solid rgba(56,189,248,.3); color: var(--s-blue); }
    .s-orange { background: rgba(249,115,22,.12); border: 1px solid rgba(249,115,22,.3); color: var(--s-orange); }
    .s-red    { background: rgba(239,68,68,.12);  border: 1px solid rgba(239,68,68,.3);  color: var(--s-red); }
    .s-yellow { background: rgba(234,179,8,.12);  border: 1px solid rgba(234,179,8,.3);  color: var(--s-yellow); }
    .s-purple { background: rgba(167,139,250,.12);border: 1px solid rgba(167,139,250,.3);color: var(--s-purple); }
    .s-gray   { background: rgba(148,163,184,.1); border: 1px solid rgba(148,163,184,.2);color: var(--s-gray); }

    /* ── Tab panes ── */
    .fsd-pane { display: none; }
    .fsd-pane.active { display: block; }

    /* ── Ticker strip ── */
    .fsd-ticker-wrap {
      margin-top: 20px;
      overflow: hidden;
      border-top: 1px solid var(--border-subtle);
      padding-top: 14px;
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .fsd-ticker-label {
      font-family: 'Share Tech Mono', monospace;
      font-size: 10px;
      letter-spacing: .2em;
      color: var(--accent-amber);
      text-transform: uppercase;
      flex-shrink: 0;
      white-space: nowrap;
    }

    .fsd-ticker-track {
      overflow: hidden;
      flex: 1;
    }

    .fsd-ticker-inner {
      display: flex;
      gap: 48px;
      white-space: nowrap;
      animation: ticker-scroll 28s linear infinite;
    }

    .fsd-ticker-item {
      font-family: 'Share Tech Mono', monospace;
      font-size: 11px;
      color: var(--text-dim);
      letter-spacing: .05em;
      flex-shrink: 0;
    }

    .fsd-ticker-item span { color: var(--accent-amber); }

    @@keyframes ticker-scroll {
      0%   { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }

    /* ── Responsive ── */
    @@media (max-width: 991px) {
      .fsd-col-headers { display: none; }

      .fsd-flight-row {
        grid-template-columns: 1fr 1fr;
        grid-template-rows: auto;
        gap: 10px 16px;
        padding: 16px;
      }

      .fsd-flight-row > .fsd-cell:nth-child(1) { grid-column: 1 / 2; }
      .fsd-flight-row > .fsd-cell:nth-child(2) { grid-column: 2 / 3; justify-content: flex-end; }
      .fsd-flight-row > .fsd-cell:nth-child(3) { grid-column: 1 / 3; }
      .fsd-flight-row > .fsd-cell:nth-child(4) { display: none; } /* hide destination on mobile */
      .fsd-flight-row > .fsd-cell:nth-child(5) { grid-column: 1 / 2; }
      .fsd-flight-row > .fsd-cell:nth-child(6) { grid-column: 2 / 3; justify-content: flex-end; }
      .fsd-flight-row > .fsd-cell:nth-child(7) { display: none; }
      .fsd-flight-row > .fsd-cell:nth-child(8) { grid-column: 1 / 3; }
    }

    @@media (max-width: 575px) {
      .fsd-title { font-size: 26px; }
      .fsd-tab-btn { padding: 8px 18px; font-size: 13px; }
    }
</style>

